    },
    "devDependencies": {
        "@antfu/eslint-config": "^9.0.0",
        "@types/node": "^24.12.4",
        "eslint": "^10.4.0",
        "rolldown": "^1.0.3",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3"
    }
}
