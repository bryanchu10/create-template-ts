{
    "name": "@bryanchu10/create-template-ts",
    "type": "module",
    "version": "1.0.2",
    "description": "Scaffold a modular TypeScript project for scripts and tooling",
    "repository": {
        "type": "git",
        "url": "https://github.com/bryanchu10/create-template-ts"
    },
    "bin": "./dist/index.js",
    "files": [
