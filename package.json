{
    "name": "@bryanchu10/create-template-ts",
    "type": "module",
    "version": "1.5.0",
    "description": "Scaffold a modular TypeScript project for scripts and tooling",
    "author": "Bryan Chu <bryanchu10@gmail.com> (https://github.com/bryanchu10)",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/bryanchu10/create-template-ts"
    },
    "keywords": [
        "scaffold",
        "typescript",
        "cli"
    ],
    "bin": "./dist/index.js",
    "files": [
        "dist",
        "templates"
    ],
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "check": "tsc --noEmit",
        "build": "rolldown -c",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "test": "vitest",
        "test:run": "vitest run",
        "verify-templates": "tsx scripts/verify-templates.ts",
        "release": "release-it"
    },
    "dependencies": {
        "@clack/prompts": "^1.4.0",
        "neverthrow": "^8.2.0",
        "ts-pattern": "^5.9.0"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^9.0.0",
        "@release-it/conventional-changelog": "^11.0.1",
        "@types/node": "^24.12.4",
        "eslint": "^10.4.0",
        "release-it": "^20.2.0",
        "rolldown": "^1.0.3",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3",
        "vitest": "^4.1.8"
    }
}
